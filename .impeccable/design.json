    "accentForeground": "oklch(0.21 0.006 285.885)",
    "destructive": "oklch(0.55 0.22 27)",
    "destructiveForeground": "oklch(0.985 0 0)",
    "border": "oklch(0.85 0.004 286.32)",
    "input": "oklch(0.85 0.004 286.32)",
